generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  AGRICULTOR
  ADMIN
  CONSUMIDOR
}

enum ProductCategory {
  HORTALIZAS
  FRUTAS
  VERDURAS
  ACEITES
  MIEL
}

enum DeliveryMode {
  NONE
  RADIUS
  TOWNS
  BOTH
}

enum ProductMeasureUnit {
  KG
  G
  L
  ML
  UNIT
}

enum OrderDeliveryType {
  PICKUP
  DELIVERY
}

enum OrderStatus {
  PENDING
  READY
  PICKED_UP
  SHIPPED
  COMPLETED
  CANCELLED
}

enum ContactMethod {
  TELEFONO
  EMAIL
  WHATSAPP
  OTRO
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(CONSUMIDOR)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  products      Product[]
  orders        Order[]
  auditLogs     AuditLog[] @relation("AuditActor")
}

model Product {
  id            String               @id @default(cuid())
  slug          String               @unique
  title         String
  description   String?
  category      ProductCategory
  minWeightKg   Decimal              @db.Decimal(10, 2)
  maxWeightKg   Decimal              @db.Decimal(10, 2)
  priceCents    Int
  shippingCents Int                  @default(0)
  zone          String
  deliveryMode  DeliveryMode        @default(NONE)
  deliveryRadiusKm Int?
  deliveryTowns String[]             @default([])
  deliveryAvailableFrom DateTime?
  deliveryAvailableTo DateTime?
  localPickup   Boolean              @default(true)
  pickupNotes   String?
  deliveryNotes String?
  saleOptions   Json?
  pricingTiers  Json?
  public        Boolean              @default(true)
  ownerId       String
  owner         User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  availability  ProductAvailability[]
  contacts      ProductContact[]
  orders        Order[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([category, public])
  @@index([zone])
}

model ProductAvailability {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())

  @@index([productId, startsAt, endsAt])
}

model ProductContact {
  id        String        @id @default(cuid())
  productId String
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  method    ContactMethod
  label     String
  value     String
  createdAt DateTime      @default(now())

  @@index([productId, method])
}

model Order {
  id             String            @id @default(cuid())
  reference      String            @unique
  ownerId        String
  owner          User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  productId      String
  product        Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerName   String
  customerEmail  String?
  customerPhone  String?
  quantity       Int               @default(1)
  deliveryType   OrderDeliveryType @default(PICKUP)
  status         OrderStatus       @default(PENDING)
  pickupAt       DateTime?
  deliveryTown   String?
  deliveryAddress String?
  customerNotes  String?
  internalNotes  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([ownerId, status, createdAt])
  @@index([productId, status])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  payload   Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
